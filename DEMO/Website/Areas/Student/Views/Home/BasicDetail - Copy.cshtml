<script type="text/javascript">
    $(document).ready(function () {
        var abc=@Convert.ToInt16(DataLayer.CommonSetting.Religion.OtherReligion);
        console.log("abc"+ abc);
        if ($('#Religion').val() == abc) {
            $('#ReligonOther').css('display', 'block');
            $('#lblrgn').css('display', 'block');
            $('#txtReligonOther').attr('required', 'required');
        }

        $('#Religion').change(function () {
            debugger;
            if ($('#Religion').val() == abc) {
                $('#ReligonOther').css('display', 'block');
                $('#txtReligonOther').attr('required', 'required');
                $('#lblrgn').css('display', 'block');

            }
            else {
                $('#ReligonOther').css('display', 'none');
                $('#txtReligonOther').removeAttr('required');
                $('#lblrgn').css('display', 'none');
                $('#txtReligonOther').val('');
            }
        });
    });
</script>
<script type="text/javascript" src="https://www.google.com/jsapi"></script>

<script type="text/javascript">
    google.load("elements", "1", { packages: "transliteration" });
</script>
<script>
    function OnLoad() {

        var options = {
            sourceLanguage:
                google.elements.transliteration.LanguageCode.ENGLISH,
            destinationLanguage:
                [google.elements.transliteration.LanguageCode.HINDI],
            shortcutKey: 'ctrl+g',
            transliterationEnabled: true
        };
        debugger;

        var control = new
            google.elements.transliteration.TransliterationControl(options);
        control.makeTransliteratable(["FirstNameInHindi"]);
        control.makeTransliteratable(["MiddleNameInHindi"]);
        control.makeTransliteratable(["LastNameInHindi"]);
        control.makeTransliteratable(["FatherNameInHindi"]);
        control.makeTransliteratable(["MotherNameInHindi"]);

    } //end onLoad function

    google.setOnLoadCallback(OnLoad);

</script>

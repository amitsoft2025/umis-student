<script>
    function toggleHandicappedDetails(isYes) {
        var section = document.getElementById("handicappedDetails");
        var type = document.getElementById("disabilityType");
        var percent = document.getElementById("disabilityPercent");

        if (isYes) {
            section.style.display = "flex";
            type.setAttribute("required", "required");
            percent.setAttribute("required", "required");
        } else {
            section.style.display = "none";
            type.removeAttribute("required");
            percent.removeAttribute("required");
            type.value = "";
            percent.value = "";
        }
    }
    window.onload = function () {
        var yesChecked = document.getElementById("ishandicappedYes")?.checked;
        toggleHandicappedDetails(yesChecked);
    };
</script>


@model DataLayer.BL_student_formcomplete
@{
    ViewBag.Title = "Student Dashboard";
    Layout = "~/Areas/Student/Views/Shared/_LayoutStudent.cshtml";
}
<style>
    .single-product-text {
        text-align: left !important;
        min-height: 400px;
    }
    .header-height{
         min-height: 10px;
    }
    .modal-header
    {
        padding:5px;
        text-align:center;
    }
    .date-style{
        font-size:12px;
        
    }
</style>

<div class="container-fluid"> 
<div class="row">
    <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
       
        <div class="single-cards-item" style="text-align:left">
            
            <div class="single-product-text dashboard-part">


                @if (ViewBag.Status != true)
                {
                    <h4><a class="" href="#">Instructions for Application Submission</a></h4>
                    <span class="counter">
                        Following are the stages for Application Submission  in the following order
                    </span>
                    <div class="row">
                        <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
                            <div class="cards-dtn">
                                <h6></h6>
                            </div>
                        </div>

                        <div class="col-md-4 col-sm-6">
                            <div class="box-col">
                                <a href="/Student/Home/BasicDetail">
                                    <div class="check-icon"><i class="fa fa-check"></i></div>
                                    <div class="row">
                                        <div class="col-xs-3 text-left">
                                            <div class="box-icon icon1"><i class="fa fa-info"></i></div>
                                        </div>
                                        <div class="col-xs-9 text-right"><span class="text-head">Basic Details</span></div>
                                    </div>
                                </a>
                            </div>
                        </div>
                        <div class="col-md-4 col-sm-6" style="display:none">
                            <div class="box-col">
                                <a href="/Student/Home/DocumentUpload">
                                    @if (Model.isdoccomplete == true)
                                         {   <div class="check-icon"><i class="fa fa-check"></i></div>}
                                    <div class="row">
                                        <div class="col-xs-3 text-left">
                                            <div class="box-icon icon2"><i class="fa fa-upload"></i></div>
                                        </div>
                                        <div class="col-xs-9 text-right"><span class="text-head">Upload Documents @if (Model.isdoccomplete == true){}</span></div>
                                    </div>
                                </a>
                            </div>
                        </div>
                        <div class="col-md-4 col-sm-6">
                            <div class="box-col">
                                <a href="/Student/Home/PreviousyearQualification">
                                    @if (Model.isqua_complete == true)
                                         {   <div class="check-icon"><i class="fa fa-check"></i></div>}
                                    <div class="row">
                                        <div class="col-xs-3 text-left">
                                            <div class="box-icon icon3"><i class="fa fa-graduation-cap"></i></div>
                                        </div>
                                        <div class="col-xs-9 text-right"><span class="text-head">Upload Qualification @if (Model.isqua_complete == true) {}</span></div>
                                    </div>
                                </a>
                            </div>
                        </div>
                        <div class="col-md-4 col-sm-6">
                            <div class="box-col">
                                <a href="/Student/Home/SelectSubject">
                                    @if (Model.ischoice_complete == true)
                                           { 
                                        <div class="check-icon"><i class="fa fa-check"></i></div>}
                                    <div class="row">
                                        <div class="col-xs-3 text-left">
                                            <div class="box-icon icon4"><i class="fa fa-book"></i></div>
                                        </div>
                                        <div class="col-xs-9 text-right"><span class="text-head">Choose Subject</span></div>
                                    </div>
                                </a>
                            </div>
                        </div>
                        <div class="col-md-4 col-sm-6">
                            <div class="box-col">
                                <a href="/Student/Home/FeesSubmit">

                                    @if (Model.isfeesubmitt == true)
                                    {  
                                        <div class="check-icon">
                                <i class="fa fa-check"></i>
                            </div>

                                    }

                                    <div class="row">
                                        <div class="col-xs-3 text-left">
                                            <div class="box-icon icon5"><i class="fa fa-money"></i></div>
                                        </div>
                                        <div class="col-xs-9 text-right"><span class="text-head">Payment of Fee</span></div>
                                    </div>
                                </a>
                            </div>
                        </div>

                    </div>
                }
                else
                {
                    <div class="alert-wrap1 shadow-inner wrap-alert-b">
                        <div class="alert alert-success " role="alert">


                            @if (ViewBag.IsApplied == true)
                            {
                                if (ViewBag.addmissionExtenddate == true && ViewBag.addmissionStartdate == true)
                                {
                                    if (ViewBag.isfeesubmitt == true)
                                    {
                                    <div class="modal-body">
                                        <div>University wants to inform you that you are being shortlisted for the  <strong>@ViewBag.College</strong>, Course- <strong>@ViewBag.Course</strong> in <strong>@ViewBag.Stream</strong> .</div>
                                        <br />
                                        <div>Admission Start Date : @ViewBag.addmissionStartdateValue and End Date : @ViewBag.addmissionExtenddateValue  .</div>
                                        <br />
                                        <div>
                                            Your Fee submission is done!!
                                            @if (ViewBag.IsfeesubmitDate != "")
                                            {
                                                <div> On @ViewBag.IsfeesubmitDate.</div>
                                            }
                                            Please visit college for updates.
                                        </div>
                                    </div>
                                    }
                                    else
                                    {
                                        if (ViewBag.IsDocVerify == 0)
                                        {
                            <div>
                                <div>University wants to inform you that you are being shortlisted for the  <strong>@ViewBag.College</strong>, Course- <strong>@ViewBag.Course</strong> in <strong>@ViewBag.Stream</strong> .</div>
                                <br />
                                <div>Admission Start Date : @ViewBag.addmissionStartdateValue and End Date : @ViewBag.addmissionExtenddateValue  .</div>
                                <br />
                                <div> For admission in Under Graduate Course !!!</div>
                                <div>
                                    Please visit the allocated college and verify your documents.
                                </div>
                            </div>

                                        }

                                        else if (ViewBag.IsDocVerify == 1)
                                        {
                            <div>
                                <div>University wants to inform you that you are being shortlisted for the  <strong>@ViewBag.College</strong>, Course- <strong>@ViewBag.Course</strong> in <strong>@ViewBag.Stream</strong> .</div>
                                <br />
                                <div>Admission Start Date : @ViewBag.addmissionStartdateValue and End Date : @ViewBag.addmissionExtenddateValue  .</div>
                                <br />
                                <div>Your document verification is done on @ViewBag.IsDocVerifyDate !!!</div>
                                Please <a href="@Url.Action("AdmissionFeeSubmit", "Home")" style="float:right">Click Here </a>   Submit fee for completing the Admission Process.
                            </div>


                                        }
                                        else if (ViewBag.IsDocVerify == 2)
                                        {
                            <div>
                                Your documents for UG admission are Rejected!!!
                                @if (ViewBag.rejectreason != "")
                                {
                                <div> Due to- @ViewBag.rejectreason Reason on  @ViewBag.IsDocVerifyDate.</div>
                                }
                            </div>

                                        }
                                    }

                                }
                                else
                                {
                                <div>University wants to inform you that you are being shortlisted for the  <strong>@ViewBag.College</strong>, Course- <strong>@ViewBag.Course</strong> in <strong>@ViewBag.Stream</strong> .</div>
                                <br />
                                <div>Admission Start Date : @ViewBag.addmissionStartdateValue and End Date : @ViewBag.addmissionExtenddateValue  .</div>
                                <br />

                                }
                            }
                        </div>
                    </div>
                    <h4><a class="" href="#">Instructions for Admission Submission</a></h4>
                    <span class="counter">
                        Following are the stages for Admission Submission  in the following order
                    </span>
                    <div class="row">
                        <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
                            <div class="cards-dtn">
                                <h6></h6>
                            </div>
                        </div>

                        <div class="col-md-5 col-sm-6 col-md-offset-1">
                            <div class="box-col">
                                <a href="#">
                                    @if (ViewBag.IsDocVerify == 1 || ViewBag.IsDocVerify == 2)
                                    {   <div class="check-icon"><i class="fa fa-check"></i></div>}
                                    <div class="row">
                                        <div class="col-xs-3 text-left">
                                            <div class="box-icon icon2"><i class="fa fa-upload"></i></div>
                                        </div>
                                        <div class="col-xs-9 text-right"><span class="text-head">Document Verification </span></div>
                                        <div class="col-xs-3 text-left">&nbsp;</div>
                                        @if (ViewBag.IsDocVerify == 1)
                                        {
                                            <div class="col-xs-9 text-right"><span class="date-style text-danger">Document VerificationDate:@ViewBag.IsDocVerifyDate </span></div>
                                        }
                                        @if (ViewBag.IsDocVerify == 2)
                                        {
                                            <div class="col-xs-9 text-right"><span class="date-style text-danger">Date Of Rejection:@ViewBag.IsDocVerifyDate due to-@ViewBag.rejectreason </span></div>
                                        }
                                    </div>
                                </a>
                            </div>
                        </div>

                        <div class="col-md-5 col-sm-6 col-md-offset-1">
                            <div class="box-col">

                                <a href="@(ViewBag.IsDocVerify==1?"/Student/Home/AdmissionFeeSubmit":"#")">

                                    @if (ViewBag.isfeesubmitt == true)
                                    {  <div class="check-icon">
                                    <i class="fa fa-check"></i>
                                </div>
                                    }

                                    <div class="row">
                                        <div class="col-xs-3 text-left">
                                            <div class="box-icon icon5"><i class="fa fa-money"></i></div>
                                        </div>
                                        <div class="col-xs-9 text-right"><span class="text-head">Payment of admission Fee</span></div>
                                        <div class="col-xs-3 text-left">&nbsp;</div>
                                        @if (ViewBag.isfeesubmitt == true)
                                        {
                                            <div class="col-xs-9 text-right"><span class="date-style text-danger">Fee Submission Date:@ViewBag.IsfeesubmitDate<br> Please visit college for updates</span></div>
                                          
     }
                                    </div>
                                </a>
                            </div>
                        </div>

                    </div>
                }

            </div>
        </div>
    </div>

</div>
</div>
@if (ViewBag.addmissionExtenddate == true && ViewBag.addmissionStartdate == true)
{
    if (ViewBag.Status == true)
    {
<div class="col-lg-6 col-md-6 col-sm-6 col-xs-12">
    <div class="">
        <div id="InformationproModalhdbgcl" class="modal modal-edu-general fullwidth-popup-InformationproModal fade" role="dialog">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header header-color-modal bg-color-2 header-height">
                        <h4 class="modal-title">Admission Process Status</h4>
                        <div class="modal-close-area modal-close-df">
                            <a class="close" data-dismiss="modal" href="#"><i class="fa fa-close"></i></a>
                        </div>
                    </div>
                    @if (ViewBag.IsApplied == true)
                    {
                        if (ViewBag.isfeesubmitt == true)
                        {   <div class="modal-body">
                        <div>
                            Your Fee submission is done!!
                            @if (ViewBag.IsfeesubmitDate != "")
                            {
                                <div> On @ViewBag.IsfeesubmitDate.</div>
                            }
                            Please visit college for updates.
                        </div>
                    </div>
                        }
                        else
                        {
                        if (ViewBag.IsDocVerify == 0)
                        {
                        <div class="modal-body">
                            <div>
                               For admission in Under Graduate Course!!!!
                                Please visit the allocated college and verify your documents.
                            </div>
                        </div>
                        }

                        else if (ViewBag.IsDocVerify == 1)
                        {
                        <div class="modal-body">
                            <div>
                                <div>Your document verification is done on @ViewBag.IsDocVerifyDate !!!</div>

                                <div> Please <span><a href="@Url.Action("AdmissionFeeSubmit","Home")">Click Here </a></span> Submit fee for completing the Admission Process.</div>

                            </div>
                        </div>
                        }
                        else if (ViewBag.IsDocVerify == 2)
                        {
                        <div class="modal-body">
                            <div>
                                Your documents for UG admission are Rejected!!!
                                @if (ViewBag.rejectreason != "")
                                {
                                    <div> Due to- @ViewBag.rejectreason Reason on  @ViewBag.IsDocVerifyDate.</div>
                                }
                            </div>
                        </div>
                        }
                        }
                        }
                        else
                        {
                        @*<div class="modal-body">
                                <div>
                                    University wants to inform you that you are being shortlisted for the  <strong>@ViewBag.College</strong>, Course- <strong>@ViewBag.Course</strong> in <strong>@ViewBag.Stream</strong> .
                                    <br/>
                                    <a href="@Url.Action("ApplyAdmission","Home")" >Click Here </a>  to complete the Admission Process.
                                     @*Congratuations You on being shortlisted for <strong><span id="course">@ViewBag.Stream</span></strong> Course,in <strong><span id="college">@ViewBag.College</span></strong>.
                                    <br />
                                    <div style="padding-bottom:20px;">&nbsp;</div>
                                        Please Click here
                                        <a href="@Url.Action("ApplyAdmission","Home")" class="btn btn-primary myBtn2 waves-effect waves-light">Apply </a>
                                    For Your Further Admission Process.

                                 </div>

                            </div>*@
                        }

                        <div class="modal-footer info-md">
                            <a data-dismiss="modal" href="#">Close</a>
                        </div>
                    </div>
            </div>
        </div>
    </div>
</div>
}
}
<script>
    $(document).ready(function () {
        debugger;
        if ('@ViewBag.addmissionExtenddate' == 'True'&&'@ViewBag.addmissionStartdate' == 'True') {
            if ('@ViewBag.Status' == 'True') {
                $("#InformationproModalhdbgcl").modal();
            }
        }

    });
</script>

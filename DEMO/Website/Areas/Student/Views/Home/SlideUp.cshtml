<script>
  $(document).on('click', '.myBtn', function () {
    //  debugger;
       
      var id = $(this).data("id");
      var collegeid = $(this).data("collegeid");
      var hounors_subjectid = $(this).data("hounors_subjectid");
      var collegeidlist = $(this).data("collegeidlist");
      var hounors_subjectidlist = $(this).data("hounors_subjectidlist");
      $('#buttonShow').attr("style", "display:none");
      $('#div_lock').attr("style", "display:none");
      $('#seat1').html('');
      
        if (id == "")
        {
            $("#collegename").val('');
            $("#honourssubjectname").val('');
            $("#hnd_subjectid").val('');
            $("#hnd_collegeid").val('');
            $("#choicetable_id").val('');
            
            return;
        }
        else
        {
            $("#collegename").html(collegeidlist);
            $("#honourssubjectname").html(hounors_subjectidlist);
            $("#hnd_subjectid").val(hounors_subjectid);
            $("#hnd_collegeid").val(collegeid);
            $("#choicetable_id").val(id);
          
     
            var headdingvalue = "";
            $("#headingnameadd").html(headdingvalue);
            $("#InformationproModalhdbgcledit").modal();
          

        }
  });

 
  $('body').delegate('#btnseatcheck', 'click', function () {
    //  debugger;
      var collegeid = $('#hnd_collegeid').val();
      var subjectid = $('#hnd_subjectid').val();
      $('#buttonShow').attr("style", "display:none");
      $('#div_lock').attr("style", "display:none");
      if (collegeid == "")
      {
          showAlert('Please Select College  !!');
          return;

      }
      if (subjectid == "")
      {
          showAlert('Please Select Subject  !!');
          return;

      }
      showloader();
      $.ajax({
          url: "/Student/Home/savest_seatavailable_slideup/",
          data: { hounors_subjectid: subjectid, collegeid: collegeid },
          cache: false,
          type: "POST",
          dataType: "json",
          success: function (data) {
              debugger;
              console.log(data.data);
              hideloader();
              if (data.data.status == true) 
              {
                
                  $('#buttonShow').removeAttr("style");
                  $('#div_lock').removeAttr("style");
                  $('#seat1').html(data.data.TotalSeat);
                  if (data.data.TotalSeat > 0)
                  {
                      $('#buttonShow').attr("style", "display:block");
                      $('#div_lock').attr("style", "display:block");
                  }
                  else {
                      $('#buttonShow').attr("style", "display:block");
                      $('#div_lock').attr("style", "display:none");
                  }
              }
              else 
              {
                  showAlert(data.data.Msg);
                  hideloader();
              }
          },
          error: function () {
              hideloader();
          }
      });
  });
  $('body').delegate('#btnseat_savaeslidup', 'click', function () {
      //debugger;
      var collegeid = $('#hnd_collegeid').val();
      var subjectid = $('#hnd_subjectid').val();
      var choicetable_id=$('#choicetable_id').val();
      if (collegeid == "") {
          showAlert('Please Select College  !!');
          return;

      }
      if (subjectid == "") {
          showAlert('Please Select Subject  !!');
          return;

      }
      var a =confirm('Are you Sure to Lock this Seat !!');
      if(a==true)
      {      //showloader();
          $.ajax({
              url: "/Student/Home/savest_slideup_admission/",
              data: { hounors_subjectid: subjectid, collegeid: collegeid, percenatge: @ViewBag.Percentage, choicetable_id: choicetable_id },
              cache: false,
              type: "POST",
              dataType: "json",
              success: function (data) {
                  //debugger;
                  hideloader();
                  console.log(data.data)
                  if (data.data.status == true)
                  {
                 
                      
                      showAlert(data.data.Msg);
                      location.reload();
                  }
                  else {
                      showAlert(data.data.Msg);
                      hideloader();
                  }
              },
              error: function () {
                  hideloader();
              }
          });
      }
  });


         
</script>

<script>
    var Coursecategory = '@ViewBag.Coursecategoryid';
    var collegelist = '';
    var gender = '@ViewBag.gender';
    //debugger;
    $(document).ready(function () {
        $.ajax({
            //  url: "/Student/Home/getcollegelist",
            ////  data: { Coursecategoryid: Coursecategory },
            //  data: { Coursecategoryid: Coursecategory },
            //  type: "POST",
            //  contentType: "application/json;charset=utf-8",
            //  dataType: "json",
            url: "/Student/Home/getcollegelist",
            data: { Coursecategoryid: Coursecategory, isgender: gender },
            cache: false,
            type: "POST",
            dataType: "json",
            success: function (result) {
                //  debugger;
                $.each(result.data, function (key, value) {
                    collegelist += '<option value="' + value.ID + '">' + value.CollegeCode + '</option>';
                });
            },
            error: function (errormessage) {
                showAlert(errormessage.responseText);
            }
        });
    });
</script>

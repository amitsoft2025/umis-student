        <h5>Transaction Detail</h5>
        <ul>
            <li><span>Transaction Status</span> : &nbsp;&nbsp;<i><img src="~/Img/check-icon1.png" width="15"></i> @Model.objPrintRecipt.status</li>
            <li><span>Transaction Date </span> : &nbsp;&nbsp;@Model.objPrintRecipt.trxdate</li>
            <li><span>Bank Reference Number</span>  : &nbsp;&nbsp;@Model.objPrintRecipt.banktrxid</li>

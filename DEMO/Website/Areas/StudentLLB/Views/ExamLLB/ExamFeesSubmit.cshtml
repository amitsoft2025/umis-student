<script type="text/javascript">Name in Devnagari
    function encodeImage(src, callback) {
        var canvas = document.createElement('canvas'),
            ctx = canvas.getContext('2d'),
            img = document.getElementById("userImage");
        img.onload = function () {
            canvas.width = 160;
            canvas.height = 150;
            ctx.drawImage(img, 0, 0, 160, 150);
            callback(canvas.toDataURL());
        }
        img.src = src;
    }
    function encodeImage1(src, callback) {
        var canvas = document.createElement('canvas'),
            ctx = canvas.getContext('2d'),
            img = document.getElementById("userSign");
        img.onload = function () {
            canvas.width = 140;
            canvas.height = 100;
            ctx.drawImage(img, 0, 0, 140, 100);
            callback(canvas.toDataURL());
        }
        img.src = src;
    }
    function encodeImage2(src, callback) {
        var canvas = document.createElement('canvas'),
            ctx = canvas.getContext('2d'),
            img = document.getElementById("logo");
        img.onload = function () {
            canvas.width = 140;
            canvas.height = 100;
            ctx.drawImage(img, 0, 0, 140, 100);
            callback(canvas.toDataURL());
        }
        img.src = src;
    }
    //function encodeImage3(src, callback) {
    //    var canvas = document.createElement('canvas'),
    //        ctx = canvas.getContext('2d'),
    //        img = document.getElementById("logoadmit");
    //    img.onload = function () {
    //        canvas.width = 140;
    //        canvas.height = 100;
    //        ctx.drawImage(img, 0, 0, 140, 100);
    //        callback(canvas.toDataURL());
    //    }
    //    img.src = src;
    //} 
</script>

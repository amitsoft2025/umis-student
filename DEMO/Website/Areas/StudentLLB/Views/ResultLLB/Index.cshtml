                            {
                                <div class="row">


                                    <div class="col-sm-6">
                                        <div class="frm_sngl_fld">
                                            <div class="form-group">
                                                <label class="control-label col-sm-3" for="pwd"> Roll no:</label>
                                                <div class="col-sm-9">
                                                    @((EncriptDecript.Decrypt(ClsLanguage.GetCookies("ENNBrollno"))))
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-sm-6">
                                        <div class="frm_sngl_fld">
                                            <div class="form-group">
                                                <label class="control-label col-sm-3" for="pwd">Exam Type:</label>
                                                <div class="col-sm-9">
                                                    @Html.DropDownListFor(model => model.isback, new System.Web.Mvc.SelectList(Model.ExaminationList, "Value", "Text"), new { @class = "form-control", @id = "ExaminationID", @required = "required" })
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="clearfix"></div>

                                    <div class="col-sm-6">
                                        <div class="frm_sngl_fld">
                                            <div class="form-group">
                                                <label class="control-label col-sm-3" for="pwd"> Semester:</label>

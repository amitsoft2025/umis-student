@model Tuple<DataLayer.AdmissionFeesSubmit, List<DataLayer.AdmissionFeesSubmit>>
@{
    ViewBag.Title = "Response";
    Layout = "~/Areas/StudentPG/Views/Shared/_LayoutStudentPG.cshtml";
}
<script>
      var logo1 = "@Convert.ToString(System.Configuration.ConfigurationManager.AppSettings["siteUrl"] + "/images/mu-logo-white.png")";
    $(function () {

        encodeImage3(logo1);
    });

</script>
<script type="text/javascript">

    function encodeImage3(src, callback) {
        var canvas = document.createElement('canvas'),
            ctx = canvas.getContext('2d'),
            img = document.getElementById("logo2");
        img.onload = function () {
            canvas.width = 140;
            canvas.height = 100;
            ctx.drawImage(img, 0, 0, 140, 100);
            callback(canvas.toDataURL());
        }
        img.src = src;
    }
</script>
<style>
    .thankyou-box {
        max-width: 750px;
        min-width: 300px;
        margin: auto;
        background-color: #FFF;
        text-align: center;
        border-radius: 40px;
        box-shadow: 10px 10px 10px #eee;
        padding: 25px;
        margin-top: -20px;
        margin-bottom: 20px;
        border: 1px solid #eee;
    }

        .thankyou-box ul {
            padding: 0;
            margin: 0;
            list-style: none;
            text-align: left;
        }

            .thankyou-box ul li {
                margin-bottom: 5px;
            }

        .thankyou-box h5 {
            border-bottom: 1px solid #ccc;
            padding-bottom: 20px;
        }

        .thankyou-box ul li span {
            width: 230px;
            display: inline-block;
        }
</style>
<script src="~/scripts/Customjs/FeessubmitPG.js"></script>

<div class="thankyou-box">
    @if (Model.Item1.FeeStatus1 == "Paid")
    {
        <i><img src="~/Img/check-icon1.png" width="75"></i>
        <p>Dear Student, Your Transaction is successful. Save the information for your reference.</p>
        <h5>Transaction Detail</h5>
        <ul>
            <li><span>Transaction Status</span> : &nbsp;&nbsp;<i><img src="~/Img/check-icon1.png" width="15"></i> @Model.Item1.FeeStatus</li>
            <li><span>Transaction Date </span> : &nbsp;&nbsp;@Model.Item1.banktxndate</li>
            <li><span>Bank Reference Number</span>  : &nbsp;&nbsp;@Model.Item1.banktrxid</li>
            <li><span>Transaction Id</span> :&nbsp;&nbsp; @Model.Item1.clienttrxid</li>
            <li><span>Application Number </span>  :&nbsp;&nbsp; @Model.Item1.ApplicationNo </li>
            <li><span>Customer Name</span> : &nbsp;&nbsp;@DataLayer.ClsLanguage.GetCookies("NBUserName")</li>
            <li><span>Fees Amount </span> : &nbsp;&nbsp;@Model.Item1.Fees</li>
            <li><span>Processingfees (including GST)</span> : &nbsp;&nbsp;@Model.Item1.surcharge</li>
            <li><span>Total Amount</span> : &nbsp;&nbsp;@(Convert.ToDecimal(Model.Item1.surcharge) + Convert.ToDecimal(Model.Item1.Fees))</li>

            <li><span>Payment Mode </span> : &nbsp;&nbsp;@Model.Item1.PaymentType</li>
            <li><span></span></li>
        </ul>
    }
    else
    {
        <i><img src="~/Img/error-icon.png" width="75"></i>
        <p>Your Transaction Failed.</p>
        <h5>Transaction Detail</h5>
        <ul>
            <li><span>Transaction Status</span> : &nbsp;&nbsp;<i><img src="~/Img/error-icon.png" width="15"></i> @Model.Item1.FeeStatus Failed</li>
            <li><span>Transaction Date </span> : &nbsp;&nbsp;@Model.Item1.banktxndate</li>
            <li><span>Bank Reference Number</span>  : &nbsp;&nbsp;@Model.Item1.banktrxid</li>
            <li><span>Transaction Id</span> : &nbsp;&nbsp;@Model.Item1.clienttrxid</li>
            <li><span>Application Number </span>  : &nbsp;&nbsp;@Model.Item1.ApplicationNo </li>
            <li><span>Customer Name</span> : &nbsp;&nbsp;@DataLayer.ClsLanguage.GetCookies("NBUserName")</li>
            <li><span>Payment Amount </span> : &nbsp;&nbsp;@Model.Item1.Fees</li>
            <li><span>Payment Mode </span> : &nbsp;&nbsp;@Model.Item1.PaymentType</li>

        </ul>
    }




    <div class="modal-area-button text-center">
        <div class="document-btn">
            @if (Model.Item1.FeeStatus1 == "Paid")
            {
                <a href="@Url.Action("AdmissionFeeSubmit", "HomePG")" class="Danger danger-color" style="float:right;color: #fff;">Click Here for Receipt </a>

            }
            else
            {
                <button class="Danger danger-color" style="color: #fff;" type="button" id="PrintRecipt"><i class="fa fa-print"></i>&nbsp;&nbsp;Download Failed Transcation Receipt</button>

                @*<button class="Danger danger-color" style="color: #fff;" type="button" id="PrintRecipt"><i class="fa fa-print"></i>&nbsp;&nbsp;</button>*@
                @*<a href="@Url.Action("AdmissionFeeSubmit", "Home")" class="Danger danger-color" style="float:right;color: #fff;">Click Here for Receipt Receipt </a>*@
            }
            @*<button class="Danger danger-color" style="color: #fff;" type="button" id="PrintRecipt"><i class="fa fa-print"></i>&nbsp;&nbsp;Download Receipt</button>*@
        </div>
    </div>
</div>

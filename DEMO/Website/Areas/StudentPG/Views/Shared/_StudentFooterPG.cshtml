@using DataLayer
@using Website.Models

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>CBCS Portal</title>

    <!-- Font Awesome for icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <!-- jQuery -->
    <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>

    <style>
        /* Loader */
        #loader {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(255,255,255,0.8);
            z-index: 99999;
            display: flex;
            justify-content: center;
            align-items: center;
            font-size: 24px;
            color: #007BFF;
        }

        /* Topbar */
        .topbar-modern {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 10px 20px;
            background: linear-gradient(90deg, #e3f2fd, #f1f9ff);
            border-bottom: 1px solid #d0e7ff;
            position: relative;
        }

        .topbar-left {
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .profile-photo {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            object-fit: cover;
            border: 2px solid #007BFF;
        }

        .user-info {
            font-size: 14px;
        }

        .user-name {
            font-weight: 600;
            font-size: 14px;
            color: #007BFF;
        }

        .user-details {
            font-size: 12px;
            color: #555;
            margin-top: 2px;
        }

        .topbar-right {
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .logout-btn {
            font-size: 14px;
            padding: 6px 12px;
            border-radius: 20px;
            border: none;
            background: #eee;
            cursor: pointer;
            transition: 0.3s;
        }

            .logout-btn:hover {
                background: #ddd;
            }

        /* Footer */
        .footer-area {
            background-color: #f1f9ff; /* light blue */
            border-top: 1px solid #d0e7ff;
            padding: 12px 20px;
            box-shadow: 0 -2px 6px rgba(0,0,0,0.05);
            margin-top: 40px;
        }

        .footer-content {
            text-align: center;
            font-size: 14px;
            color: #555;
            font-family: 'Segoe UI', sans-serif;
        }

            .footer-content i {
                color: #007BFF;
                margin-right: 4px;
            }
    </style>
</head>
<body>

    <!-- Loader -->
    <div id="loader">Loading...</div>

    <!-- Topbar -->
    <div class="topbar-modern">
        <div class="topbar-left">
            <img src='@System.Configuration.ConfigurationManager.AppSettings["AmozonbucketPath"]/Student/Photoandsign/@DataLayer.ClsLanguage.GetCookies("NBphoto")'
                 alt="Profile Photo" onerror="this.src='~/images/noimage.png'" class="profile-photo">
            <div class="user-info">
                <div class="user-name">@DataLayer.ClsLanguage.GetCookies("NBUserName")</div>
                <div class="user-details">@DataLayer.ClsLanguage.GetCookies("courseyear")</div>
            </div>
        </div>

        <div class="topbar-right">
            <button class="logout-btn">
                Logout <i class="fa fa-sign-out-alt"></i>
            </button>
        </div>
    </div>

    <!-- Page content placeholder -->
    <div class="container-fluid" style="padding: 20px;">
        <h2>Welcome to CBCS Academic Portal</h2>
        <p>Your content goes here.</p>
    </div>

    <!-- Footer -->
    <div class="footer-area">
        <div class="container-fluid">
            <div class="footer-content">
                <span><i class="fa fa-university"></i> CBCS Academic Portal</span> •
                <span><i class="fa fa-lock"></i> Secure Access</span> •
                <span><i class="fa fa-user-shield"></i> Authorized Access Only</span>
            </div>
        </div>
    </div>

    <!-- Scripts -->
    <script>
        $(document).ready(function() {
            // Hide loader after page load
            $("#loader").fadeOut();

            // Logout button click
            $(".logout-btn").on("click", function(){
                localStorage.removeItem("logged_in");
                window.location.href = "/custom-login";
            });

            // Storage listener for logout
            window.addEventListener('storage', function (event) {
                if (event.key === 'logged_in') {
                    localStorage.removeItem("logged_in");
                    window.location.href = "/custom-login";
                }
            });
        });
    </script>

</body>
</html>
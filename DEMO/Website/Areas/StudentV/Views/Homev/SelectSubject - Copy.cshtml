                    debugger;
                    if ($(this).val() == "") {
                        return;
                    }

                    var empTab = document.getElementById('subjecttable');
                    var rowindex = $(this).closest("tr").index();
                    var rowsubjectid = $(this).val();
                    var rowcollgeid = tr.find('#College').val();

                    var collegeitemvalues = $('Select[name="College"] ').map(function () {
                        return this.value
                    }).get();
                    var honusreitemvalues = $('Select[name="Subject"] ').map(function () {
                        return this.value
                    }).get();
                    var error = '';
                    if (rowindex > 0) {
                        if (collegeitemvalues.length > 0) {
                            for (var i = 0; i < collegeitemvalues.length; i++) {
                                if (i == rowindex)
                                { }
                                else
                                {
                                    if (collegeitemvalues[i] != '') {
                                        if (collegeitemvalues[i] == rowcollgeid && honusreitemvalues[i] == rowsubjectid) {
                                            error = 'you have already Selected this Honours Subjects for this College !!';
                                        }
                                    }
                                }
                            }
                        }
                        if (error != '') {
                            showAlert(error);
                            $(this).val('');
                            return;
                        }
                    }


                                                        <a title="Edit" href="~/StudentV/Homev/PreviousyearQualification/{{qualidetail.encriptedID}}" class="btn btn-success btn-sm fa fa-edit " onclick="return confirm('If you have already filled your subject and college choices, it will be deleted ,if you edit your Qualification!!');"></a>

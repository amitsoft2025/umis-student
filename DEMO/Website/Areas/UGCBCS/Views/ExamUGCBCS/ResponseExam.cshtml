            <li><span>Bank Reference Number</span>  : &nbsp;&nbsp;@Model.objPrintRecipt.banktrxid</li>
            <li><span>Transaction Id</span> : &nbsp;&nbsp;@Model.objPrintRecipt.TransactionId</li>
            <li><span>Application Number </span>  : &nbsp;&nbsp;@Model.Examobjfeesubmit.ApplicationNo </li>
            <li><span>Customer Name</span> : &nbsp;&nbsp;@DataLayer.ClsLanguage.GetCookies("NBUserName")</li>
            <li><span>Payment Amount </span> : &nbsp;&nbsp;@(Model.Examobjfeesubmit.late_fee + Convert.ToDecimal(Model.Examobjfeesubmit.Fees))</li>
            <li><span>Payment Mode </span> : &nbsp;&nbsp;@Model.objPrintRecipt.PaymentType</li>


}

<script>
    var photurl = "@Convert.ToString(System.Configuration.ConfigurationManager.AppSettings["AmozonbucketPath"]+"/Student/Photoandsign/"+Model.objExamFrom.photo)";
    var signurl = "@Convert.ToString(System.Configuration.ConfigurationManager.AppSettings["AmozonbucketPath"]+"/Student/Photoandsign/"+ Model.objExamFrom.sign)";
    var logo1 = "@Convert.ToString(System.Configuration.ConfigurationManager.AppSettings["siteUrl"] + "/images/mu-logo-white.png")";
    $(function () {

        encodeImage2(logo1);
    });

</script>

<script type="text/javascript">

    function encodeImage2(src, callback) {
        var canvas = document.createElement('canvas'),
            ctx = canvas.getContext('2d'),
            img = document.getElementById("logo");
        img.onload = function () {
            canvas.width = 140;
            canvas.height = 100;
            ctx.drawImage(img, 0, 0, 140, 100);
            callback(canvas.toDataURL());
        }
        img.src = src;
    }

</script>
<style>
    .thankyou-box {
        max-width: 700px;
        min-width: 300px;
        margin: auto;
        background-color: #FFF;
        text-align: center;
        border-radius: 40px;
        box-shadow: 10px 10px 10px #eee;
        padding: 25px;
        margin-top: 0px;
        margin-bottom: 20px;
        border: 1px solid #eee;
    }

        .thankyou-box ul {
            padding: 0;
            margin: 0;
            list-style: none;
            text-align: left;
        }

            .thankyou-box ul li {
                margin-bottom: 5px;
            }

        .thankyou-box h5 {
            border-bottom: 1px solid #ccc;
            padding-bottom: 20px;
        }

        .thankyou-box ul li span {
            width: 180px;
            display: inline-block;
        }

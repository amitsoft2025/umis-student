<script src="~/scripts/Customjs/ExamFeeSubmitPG.js?id=@System.Configuration.ConfigurationManager.AppSettings["Commonjs"]"></script>

<div class="thankyou-box">
    @if (Convert.ToString(Model.Examobjfeesubmit.FeeStatus).ToLower() == "Paid".ToLower())
    {
        <i><img src="~/Img/check-icon1.png" width="75"></i>
        <p>Dear Student, Your Transaction is successful. Save the information for your reference.</p>
        <h5>Transaction Detail</h5>
        <ul>
            <li><span>Transaction Status</span> : &nbsp;&nbsp;<i><img src="~/Img/check-icon1.png" width="15"></i> @Model.objPrintRecipt.status</li>
            <li><span>Transaction Date </span> : &nbsp;&nbsp;@Model.objPrintRecipt.trxdate</li>
            <li><span>Bank Reference Number</span>  : &nbsp;&nbsp;@Model.objPrintRecipt.banktrxid</li>

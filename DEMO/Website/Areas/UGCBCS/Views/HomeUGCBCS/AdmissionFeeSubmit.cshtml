    <style>
        .stepper {
            display: flex;
            justify-content: space-between;
            margin: 25px 0;
            padding: 0;
            list-style: none;
        }

        .step {
            text-align: center;
            flex: 1;
            position: relative;
        }

            .step::before {
                content: "";
                position: absolute;
                top: 18px;
                left: -50%;
                width: 100%;
                height: 3px;
                background: #e5e7eb;
                z-index: 0;
            }

            .step:first-child::before {
                display: none;
            }

        .step-circle {
            width: 36px;
            height: 36px;
            line-height: 36px;
            border-radius: 50%;
            background: #e5e7eb;
            color: #6b7280;
            margin: 0 auto;
            font-weight: 600;
            position: relative;
            z-index: 1;
        }

        /* 🔥 number hide when tick comes */
        .step.completed .step-circle {
            font-size: 0;
        }

            /* Tick */
            .step.completed .step-circle::after {
                content: "✔";
                font-size: 16px;
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
            }

        /* Title */
        .step-title {
            margin-top: 8px;
            font-size: 13px;
            color: #6b7280;
        }

        /* Active (blue current step) */
        .step.active .step-circle {
            background: #3b82f6;
            color: #fff;
        }

        .step.active .step-title {
            color: #111827;
            font-weight: 600;
        }

        /* Completed (green) */
        .step.completed .step-circle {
            background: #22c55e;
            color: #fff;
        }

        .step.completed::before {
            background: #22c55e;
        }
    </style>

    <style>
        .step a {
            text-decoration: none;
            color: inherit;
            display: block;
        }

            .step a:hover {
                transform: scale(1.05);
                transition: 0.2s;
            }
    </style>



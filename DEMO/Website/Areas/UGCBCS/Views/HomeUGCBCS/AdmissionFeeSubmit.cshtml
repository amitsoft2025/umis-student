<script>
    $(document).on('click', '#PrintRecipt', function () {

        var DivName = $('#dvPrintRecipt');

        if (DivName.length == 0) {
            alert("Receipt not found!");
            return;
        }

        var printContents = `
            <html>
            <head>
                <title>Receipt</title>
                <meta charset="utf-8"/>
            </head>
            <body>` + DivName.html() + `</body></html>`;

        // REMOVE OLD FORM IF EXISTS
        $('#tempForm2').remove();

        // CREATE NEW FORM
        var form = `
            <form method="post" action="/UGCBCS/HomeUGCBCS/PrintApplicationCallReceipt" id="tempForm2">
                <input type="hidden" name="data1" value='${printContents.replace(/'/g, "&apos;")}' />
                <input type="hidden" name="dataname1" value="AdmissionFeeRecipt" />
                <input type="hidden" name="PageType1" value="Portrait" />
            </form>`;

        $('body').append(form);

        // SUBMIT
        $('#tempForm2').submit();

        // CLEANUP
        setTimeout(function () {
            $('#tempForm2').remove();
        }, 1000);
    });
</script>


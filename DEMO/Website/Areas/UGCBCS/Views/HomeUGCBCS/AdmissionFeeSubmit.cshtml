    @{
        int step = ViewBag.IsCurrent != null ? Convert.ToInt32(ViewBag.IsCurrent) : 1;
    }
    <script>
function handleStepClick(stepNumber, bypassBlock = false) {

    var currentStep = @step;

    // 🚫 Future step block
    if (!bypassBlock) {
        if (stepNumber > currentStep) {
            return;
        }
    }

    // ✅ Show content
    document.querySelectorAll('.content-box').forEach(function (el) {
        el.classList.remove('active');
    });

    document.getElementById('step' + stepNumber).classList.add('active');
}

// ✅ Page load → CURRENT step open
window.onload = function () {
    handleStepClick(@step, true);
};
    </script>


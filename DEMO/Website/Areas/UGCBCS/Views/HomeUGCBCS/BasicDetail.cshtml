@model DataLayer.Login
@{

    Layout = "~/Areas/UGCBCS/Views/Shared/_LayoutStudentPG.cshtml";
}
<style>
    body {
        background: #e0e8f5 !important;
        font-family: 'Roboto', sans-serif;
        padding: 0;
        margin: 0;
    }

    label {
        padding: 10px;
    }

    .starvalid {
        color: red;
    }

    .spacetop {
        padding-top: 20px;
    }
    /* Alert container */
    .custom-alert-wrap {
        position: fixed; /* top pe dikhaye */
        top: 20px;
        left: 50%;
        transform: translateX(-50%);
        z-index: 99999;
        width: auto;
        max-width: 500px;
        animation: slideDownFade 0.5s ease-out;
    }

    /* Alert box */
    .custom-alert {
        background: linear-gradient(135deg, #6DD5FA, #2980B9); /* stylish blue gradient */
        color: #fff;
        padding: 15px 25px;
        border-radius: 12px;
        box-shadow: 0 6px 15px rgba(0, 0, 0, 0.2);
        font-size: 16px;
        text-align: center;
        font-weight: 500;
        border-left: 5px solid #fff; /* accent line */
        animation: fadeOut 0.3s ease-in 3s forwards; /* fade out after 3s */
    }

    /* Slide down + fade in */
    @@keyframes slideDownFade {
        0% {
            transform: translate(-50%, -50px);
            opacity: 0;
        }

        100% {
            transform: translate(-50%, 0);
            opacity: 1;
        }
    }

    /* Fade out */
    @@keyframes fadeOut {
        0% {
            opacity: 1;
        }

        100% {
            opacity: 0;
            display: none;
        }
    }
</style>

<style>
    .form-control, .form-select {
        width: 100%;
        padding: 0.85rem 1rem !important;
        font-size: 1.3rem !important;
        border: 1.5px solid #e2e8f0 !important;
        border-radius: 1.2rem !important;
        background: #ffffff !important;
        transition: all 0.25s ease;
        outline: none;
    }

    .form-card {
        background: rgba(255, 255, 255, 0.96) !important;
        backdrop-filter: blur(2px) !important;
        border-radius: 2rem !important;
        padding: 1.8rem !important;
        margin-bottom: 1.5rem !important;
        box-shadow: 0 20px 35px -12px rgba(0, 0, 0, 0.1), 0 1px 3px rgba(0, 0, 0, 0.02);
        transition: all 0.35s cubic-bezier(0.2, 0.9, 0.4, 1.1);
        border: 1px solid rgba(255, 255, 255, 0.7) !important;
    }

    .card-header-custom {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 1.5rem !important;
        padding-bottom: 0.75rem !important;
        border-bottom: 2px solid rgba(91, 134, 229, 0.2);
    }

        .card-header-custom h2 {
            font-size: 1.8rem !important;
            font-weight: 700;
            color: #1e293b;
            margin: 0;
        }

        .card-header-custom p {
            margin: 0;
            font-size: 1rem;
            color: #5b6e8c;
        }

        .card-header-custom i
        Specificity: (0,1,1) {
            font-size: 1.8rem;
            background: linear-gradient(135deg, #667eea, #764ba2);
            background-clip: text;
            -webkit-background-clip: text;
            color: transparent;
        }

    .upload-area-wrapper {
        display: flex;
        flex-wrap: wrap;
        gap: 1.5rem;
        margin-top: 1rem;
    }

    .btn-submit-premium {
        background: linear-gradient(105deg, #1E2A5E, #2E4A8E, #5b86e5);
        border: none;
        width: 50%;
        padding: 1rem !important;
        font-size: 1.5rem !important;
        font-weight: 700;
        color: white;
        border-radius: 2rem !important;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 12px;
        transition: all 0.3s ease;
        margin-top: 0.5rem;
        box-shadow: 0 8px 20px rgba(46, 74, 142, 0.3);
    }

    .upload-tile {
        flex: 1;
        min-width: 180px;
        background: #f9fbfe;
        border-radius: 1.5rem;
        padding: 1.2rem;
        text-align: center;
        transition: all 0.3s;
        border: 1px solid #eef2ff;
    }

    .preview-image-circle {
        width: 110px;
        height: 110px;
        border-radius: 1.2rem;
        object-fit: cover;
        margin: 0 auto 0.8rem;
        border: 3px solid white;
        box-shadow: 0 6px 14px rgba(0, 0, 0, 0.1);
        background: #eef2ff;
    }

    .preview-signature-box {
        width: 130px;
        height: 65px;
        border-radius: 1rem;
        object-fit: contain;
        margin: 0 auto 0.8rem;
        background: #fff6e5;
        border: 1px dashed #cbd5e1;
        padding: 5px;
    }

    .upload-btn-modern {
        background: linear-gradient(135deg, #667eea, #764ba2);
        color: white;
        border: none;
        padding: 0.6rem 1.2rem !important;
        border-radius: 2rem !important;
        font-size: 0.8rem;
        font-weight: 600;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: all 0.2s;
        margin-top: 8px;
    }

    .file-info {
        font-size: 0.7rem !important;
        color: #6c757d;
        margin-top: 6px;
    }
</style>
<script type="text/javascript">

    function show(input) {
        debugger;
        if (input.files && input.files[0]) {
            var filerdr = new FileReader();
            filerdr.onload = function (e) {
                $('#userImage').attr('src', e.target.result);
                $('#hstphoto').val(e.target.result);
            }
            filerdr.readAsDataURL(input.files[0]);

        }
    }

    function show1(input) {
        if (input.files && input.files[0]) {
            var filerdr1 = new FileReader();
            filerdr1.onload = function (e) {
                $('#signImage').attr('src', e.target.result);
                $('#hstsign').val(e.target.result);

            }
            filerdr1.readAsDataURL(input.files[0]);
        }
    }
</script>

<script>
    function checkphotosign() {
        showAlert('test');
        var photo = document.getElementById('photo').files.length;
        var sign = document.getElementById('sign').files.length;

        if (photo === 0) {
            showAlert("Please upload your photo.");
            return false;
        }

        if (sign === 0) {
            showAlert("Please upload your signature.");
            return false;
        }

        return true; // Form submit ho jayega
    }
   
</script>

<script>
   function submitForm() {
       alert('test');
    if (!checkphotosign()) return;

    var form = $("#myform");

    if (!form[0].checkValidity()) {
        form[0].reportValidity();
        return;
    }

    var formData = new FormData(form[0]);

    $(".btn").prop("disabled", true);
    showloader();

    $.ajax({
        url: '/update-profile', // 👈 route use ho raha hai
        type: 'POST',
        data: formData,
        processData: false,
        contentType: false,

        success: function (res) {

            hideloader();
            $(".btn").prop("disabled", false);

            if (res.Status == 1) {
                showAlert(res.Msg || "Saved Successfully");

                setTimeout(function () {
                    location.href = '/dashboard';
                }, 1000);
            } else {
                showAlert(res.Msg || "Something went wrong");
            }
        },
        error: function (err) {

            hideloader();
            $(".btn").prop("disabled", false);

            console.log(err);
            showAlert("Server error, try again!");
        }
    });
}
</script>
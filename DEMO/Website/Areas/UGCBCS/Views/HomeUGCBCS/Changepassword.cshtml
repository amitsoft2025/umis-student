@model DataLayer.ChangePassword
@{
    ViewBag.Title = "Update Password";
    Layout = "~/Areas/UGCBCS/Views/Shared/_LayoutStudentPG.cshtml";
}

<style>
    body {
        background: #f1f5f9;
        font-family: 'Segoe UI', sans-serif;
    }

    .container-box {
        max-width: 500px;
        margin: 40px auto;
        background: #fff;
        padding: 25px;
        border-radius: 12px;
        box-shadow: 0 5px 20px rgba(0,0,0,0.08);
    }

    .title {
        text-align: center;
        font-size: 22px;
        font-weight: 600;
        margin-bottom: 15px;
        color: #1e3a8a;
    }

    .warning {
        background: #fff3cd;
        color: #856404;
        padding: 10px;
        border-radius: 8px;
        font-size: 13px;
        margin-bottom: 15px;
        border-left: 4px solid #ffc107;
    }

    .form-group {
        margin-bottom: 15px;
    }

        .form-group label {
            font-size: 13px;
            font-weight: 600;
            display: block;
            margin-bottom: 5px;
        }

        .form-group input {
            width: 100%;
            padding: 12px 42px 12px 12px;
            border-radius: 20px; /* more rounded */
            border: 1px solid #cbd5e1;
            outline: none;
            transition: 0.3s;
        }

            .form-group input:focus {
                border-color: #2563eb;
            }

    /* 🔴 error state */
    .error {
        border-color: red !important;
        background: #ffe5e5;
    }

    .error-text {
        color: red;
        font-size: 12px;
        margin-top: 3px;
    }

    .btn {
        width: 100%;
        padding: 10px;
        border-radius: 8px;
        border: none;
        background: #2563eb;
        color: white;
        font-weight: 600;
        cursor: pointer;
    }

        .btn:disabled {
            background: #94a3b8;
            cursor: not-allowed;
        }
</style>

<div class="container-box">

    <div class="title">Update Password</div>

    <div class="warning">
        ⚠️ If this is your first login, you must change your password before continuing.
    </div>

    <div class="form-group">
        <label>Old Password</label>
        <input type="password" id="oldpassword" />
    </div>

    <div class="form-group">
        <label>New Password</label>
        <div style="position:relative;">
            <input type="password" id="newpassword" />
            <span onclick="toggle('newpassword')" style="position:absolute;right:12px;top:50%;transform:translateY(-50%);cursor:pointer;color:#2563eb;">👁</span>
        </div>
    </div>

    <div class="form-group">
        <label>Confirm Password</label>
        <div style="position:relative;">
            <input type="password" id="confpassword" />
            <span onclick="toggle('confpassword')" style="position:absolute;right:12px;top:50%;transform:translateY(-50%);cursor:pointer;color:#2563eb;">👁</span>
        </div>
        <div id="matchError" class="error-text"></div>
    </div>

    <button id="btnSubmit" class="btn" onclick="submitapplication()" disabled>
        Update Password
    </button>

</div>

<script>

    function toggle(id) {
        var input = document.getElementById(id);
        input.type = input.type === "password" ? "text" : "password";
    }


    function checkForm() {
        var oldpassword = $("#oldpassword").val();
        var newpassword = $("#newpassword").val();
        var confpassword = $("#confpassword").val();

        // reset
        $("#confpassword").removeClass("error");
        $("#matchError").text("");

        let valid = true;

        if (!oldpassword) valid = false;
        if (!newpassword || newpassword.length < 6) valid = false;
        if (!confpassword) valid = false;

        // 🔴 mismatch
        if (newpassword && confpassword && newpassword !== confpassword) {
            $("#confpassword").addClass("error");
            $("#matchError").text("Password does not match");
            valid = false;
        }

        $("#btnSubmit").prop("disabled", !valid);
    }

    $("#oldpassword, #newpassword, #confpassword").on("keyup", checkForm);

    function submitapplication() {

        var obj = {
            CurrentPassword: $("#oldpassword").val(),
            NewPassword: $("#newpassword").val(),
            ConfirmPassword: $("#confpassword").val()
        };

        showloader();

        $.ajax({
            url: "update-Password",
            data: JSON.stringify(obj),
            type: "POST",
            contentType: "application/json;charset=utf-8",
            dataType: "json",
            success: function (result) {
                hideloader();
                showAlert(result.Msg);

                if (result.Status == 1) {
                    setTimeout(function () {
                        location.replace('/dashboard');
                    }, 1000);
                }
            },
            error: function (err) {
                hideloader();
                showAlert(err.responseText);
            }
        });
    }

</script>

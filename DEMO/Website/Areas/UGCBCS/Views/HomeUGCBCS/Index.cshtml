@model DataLayer.BL_student_formcomplete
@{
    ViewBag.Title = "Dashboard";
    Layout = "~/Areas/UGCBCS/Views/Shared/_LayoutStudentPG.cshtml";
}
<style>
    .single-product-text {
        text-align: left !important;
        min-height: 400px;
    }
    </style>

<script>
    document.addEventListener("keydown", function (e) {
        if (e.keyCode == 123) {
            e.preventDefault();
        }
    });
    document.addEventListener("contextmenu", function (e) {
        e.preventDefault();
    });
</script>

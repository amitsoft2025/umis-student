<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd">

<html xmlns="http://www.w3.org/1999/xhtml">
<head id="Head1" runat="server">
    <title>Munger University -Payment Gateway </title>
    <script>

        $(document).ready(function ()
        { generateAction(); });
             function generateAction()
             {
                   @*var url='@ViewBag.url';
                 var me_id = '@ViewBag.me_id';
                 var merchant_request='@ViewBag.merchant_request';
                 var hash = '@ViewBag.hash';*@

                 //document.frmPost.me_id.value = '20220329007';
                 //document.frmPost.merchant_request.value = '';
                 //document.frmPost.hash.value = 'Ok6Zst9bVLXebtZKkksW9bc3jYriJsGpiwqCSLAo44oVpPZR+UrFIXejM1AvjP/521QzZd5HOl1ONMTWsMrRVxtFXf/y4tk9auQcvFGTKHI=';
                 //document.frmPost.action = 'https://www.avantgardepayments.com/agcore/paymentProcessing';
                 var url = '@ViewBag.url';
                 var me_id = '@ViewBag.me_id';
                 var merchant_request = '@ViewBag.merchant_request';
                 var hash = '@ViewBag.hash';
                 document.frmPost.me_id.value = me_id;
                 document.frmPost.merchant_request.value = merchant_request;
                 document.frmPost.hash.value = hash;
                 document.frmPost.action = url;
                 document.frmPost.submit();
            }
    </script>
</head>
<body>


    <form name="frmPost" method="post">
        <table width="300px">
            <tr>
                <td width="120px"></td>
                <td width="20px">
                    @*<input type="hidden" name="orderid" value="" />*@
                    <input type="hidden" name="me_id" value="" />
                    <input type="hidden" name="merchant_request" value="" />
                    <input type="hidden" name="hash" value="" />
                </td>

                <td>
                    <input type="submit" value="Pay Now" onclick="generateAction();" id="Submit1" name="Submit1" style="display:none" />
                </td>
            </tr>
            <tr>
                <td colspan="3"></td>
            </tr>
        </table>
        <script type="text/javascript">
            window.onload = function () {
                document.frmPost.Submit1.click();
            }
        </script>
    </form>
</body>
</html>

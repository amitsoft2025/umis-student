                                                                   @required = "required",
                                                                   @oninput = "Onlynumericvalue(this);",
                                                                   @maxlength = "3", /*@Value = item.TotalMarks*/@Value="100"
                                                                  
                                                               })
                                                                </td>
                                                            }

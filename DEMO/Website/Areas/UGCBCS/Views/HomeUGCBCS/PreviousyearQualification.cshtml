                                                                    @Html.TextBox("TotalMarks", "", new
                                                               {
                                                                   @class = "form-control TotalMarks ",
                                                                   @id = "TotalMarks",
                                                                   @name = "TotalMarks",
                                                                   @required = "required",
                                                                   @oninput = "Onlynumericvalue(this);",
                                                                   @maxlength = "3", /*@Value = item.TotalMarks*/
                                                                   @Value = "50"
                                                                   
                                                               })
                                                                </td>
                                                            }

                                                                    @Html.DropDownList("SubjectLLID", new SelectList(ViewBag.LLSubject, "ID", "SubjectName", item.SubjectID), "--Select LL Subject--", new { @class = "form-control custom-select-value ", @id = "SubjectLLID", @required = "required"  })

                    tr.find('#Subject ').append($("<option></option>").val("").html("--Select Subject--"));
                  
                    if ($(this).val() == "") {
                        return;
                    }

                    showloader();
                    $.ajax({
                        url: "/UGCBSC/HomeUGCBCS/getcollegesubjects/",
                        data: { id: res },
                        cache: false,
                        type: "POST",
                        dataType: "json",

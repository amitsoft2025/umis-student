                        success: function (data) {
                            hideloader();
                            console.log(data.data);
                            showAlert(data.data.Msg);
                            showloader();
                            $('option:selected', 'select[name="College"]').removeAttr('selected');

                            location.replace('/HomeUGCBCS/HomeUGCBCS/SelectSubject');
                            window.location.reload();
                        },
                        error: function () {
                            hideloader();
                            showAlert("error")
                        }
                    });
                    return;
                });
                function removeRow(oButton) {
                    var empTab = document.getElementById('subjecttable');
                    empTab.deleteRow(oButton.parentNode.parentNode.rowIndex);       // BUTTON -> TD -> TR.
                }
                $("#changeschoices").click(function (event) {
                    debugger;
                    var a = confirm("Your All Choices will be Deleted and you need to fill All Choices Again ??");
                    if (a == true) {
                        showloader();
                        $.ajax({
                            url: "/HomeUGCBCS/HomeUGCBCS/againfillform/",
                            data: {},
                            cache: false,
                            type: "POST",
                            dataType: "json",
                            success: function (data) {
                                hideloader();
                                showloader();
                                $('option:selected', 'select[name="College"]').removeAttr('selected');
                                location.replace('/HomeUGCBCS/HomeUGCBCS/SelectSubject');
                                window.location.reload();
                            },
                            error: function () {
                                hideloader();

                            }
                        });
                    }
                    else {

                        return;
                    }
                });
</script>


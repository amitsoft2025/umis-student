        /* Small subtle spinner */
        #AjaxLoader {
            position: fixed;
            top: 10px;
            right: 10px;
            z-index: 99999;
        }

        .mini-loader {
            border: 3px solid rgba(0,0,0,0.2);
            border-top: 3px solid #007BFF;
            border-radius: 50%;
            width: 25px;
            height: 25px;
            animation: miniSpin 0.8s linear infinite;
        }

        keyframes miniSpin {
            0%

        {
            transform: rotate(0deg);
        }

        100% {
            transform: rotate(360deg);
        }

        }

        .edu-loader {
            position: fixed !important;
            top: 0 !important;
            left: 0 !important;
            width: 100vw;
            height: 100vh;
            background: rgba(255,255,255,0.95);
            z-index: 9999999;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .edu-loader-box .ring {
            position: absolute;
            width: 120px;
            height: 120px;
            border: 4px solid transparent;
            border-top: 4px solid #4e73df;
            border-radius: 50%;
            animation: spin 1.2s linear infinite;
        }

        keyframes spin {
            100%

        {
            transform: rotate(360deg);
        }
        }
    </style>

    <script>
        function showloader() {
            $('#AjaxLoader').fadeIn();
        }

        function hideloader() {
            $('#AjaxLoader').fadeOut();
        }
    </script>
    <style>
        .edu-loader {
            position: fixed !important;
            top: 0 !important;
            left: 0 !important;
            width: 100vw;
            height: 100vh;
            background: rgba(255,255,255,0.95);
            z-index: 9999999;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .edu-loader-box {
            position: relative;
            width: 120px;
            height: 120px;
        }

        .ring {
            position: absolute;
            width: 100%;
            height: 100%;
            border: 4px solid transparent;
            border-top: 4px solid #4e73df;
            border-radius: 50%;
            animation: spin 1.2s linear infinite;
        }

            .ring:nth-child(2) {
                border-top: 4px solid #1cc88a;
                animation-delay: 0.3s;
            }

            .ring:nth-child(3) {
                border-top: 4px solid #36b9cc;
                animation-delay: 0.6s;
            }

        @@keyframes spin {
            100% {
                transform: rotate(360deg);
            }
        }

        .logo-text {
            position: absolute;
            width: 100%;
            text-align: center;
            top: 40%;
            font-size: 14px;
            font-weight: bold;
            color: #4e73df;
        }
    </style>


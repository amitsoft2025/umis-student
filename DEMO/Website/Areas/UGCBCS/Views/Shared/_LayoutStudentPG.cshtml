<style>

      .custom-alert {
    display: none;
    position: fixed;
    z-index: 99999;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0,0,0,0.6);
    justify-content: center;
    align-items: center;
}

.alert-box {
    width: 380px;
    background: #fff;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 10px 25px rgba(0,0,0,0.3);
    animation: popup 0.3s ease;
}

/* Header */
.alert-header {
    background: linear-gradient(45deg, #004aad, #007bff);
    color: #fff;
    padding: 12px;
    font-size: 18px;
    font-weight: 600;
    text-align: center;
}

        /* 🔴 Error / Warning */
        .alert-header.error {
            background: linear-gradient(45deg, #b30000, #ff4d4d);
        }


/* Body */
.alert-body {
    padding: 20px;
    text-align: center;
    font-size: 15px;
    color: #333;
}

/* Footer */
.alert-footer {
    text-align: center;
    padding-bottom: 15px;
}

.alert-footer button {
    background: #007bff;
    color: #fff;
    border: none;
    padding: 7px 25px;
    border-radius: 6px;
    cursor: pointer;
    transition: 0.3s;
}

.alert-footer button:hover {
    background: #0056b3;
}

/* Animation */
keyframes popup {
    from {
        transform: scale(0.7);
        opacity: 0;
    }
    to {
        transform: scale(1);
        opacity: 1;
    }
}
</style>










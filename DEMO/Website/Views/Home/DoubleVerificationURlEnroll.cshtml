
@{
    ViewBag.Title = "DoubleVerificationURlEnroll";
    Layout = "~/Views/Shared/_LayoutHome.cshtml";
}


@{
    Layout = null;
}

<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>DoubleVerificationURl Registration</title>
</head>

<body>
    @if (TempData["responseString"] != null)
    {
        <div>@TempData["responseString"]</div><br /><br />
    }

    <div>
        @using (Html.BeginForm("DoubleVerificationURlEnroll", "Home", FormMethod.Post, new { id = "myform", enctype = "multipart/form-data" }))
        {
            <br />
            @Html.TextBox("trxid", "", new { @class = "form-control", @required = "required", @placeholder = "Orderno" })

            <br />            <br />
            @Html.TextBox("password", "", new { @class = "form-control", @required = "required", @placeholder = "password" })

            <br />            <br />
            <input type="submit" value="submit Loop" />

        }

    </div>

    <div>
        @using (Html.BeginForm("DoubleVerificationURlEnrollSee", "Home", FormMethod.Post, new { id = "myform", enctype = "multipart/form-data" }))
        {
            <br />
            @Html.TextBox("trxid", "", new { @class = "form-control", @required = "required", @placeholder = "Orderno" })

            <br />            <br />
            @Html.TextBox("password", "", new { @class = "form-control", @required = "required", @placeholder = "password" })

            <br />            <br />

            <br />            <br />
            <input type="submit" value="Only See Status" />

        }

    </div>
</body>
</html>

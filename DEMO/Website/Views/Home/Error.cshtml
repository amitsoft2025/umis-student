    <div class="error-pagewrap">
        <div class="error-page-int">
            <div class="content-error">
                <h1>Server Error <span class="counter"> </span></h1>
             
                <div style="background-color: #A52A2A;  height: 10px;">
                </div>
                <div style="background-color: #F5F5DC;  height: 170px;">
                    <div style="padding:20px;">
                        <h3>
                            Application Error:
                        </h3>
                        <h4>
                            <p>The server encountered something unexpected that didn't allow it to complete the request. We apologize.</p>
                        </h4>
                        <h6>@Html.ActionLink("Go Back To Home Page", "Index", "Home")</h6>
                        <br />
                        <br />
                    </div>
                </div>  
              
            </div>
            <div class="text-center login-footer">
                <div class="text-center login-footer">
                    <p>Copyright ©  @DateTime.Now.Year.ToString()  <span>@DataLayer.CommonSetting.ProjectName</span>. All rights reserved. </p>
                </div>
            </div>
        </div>
    </div>

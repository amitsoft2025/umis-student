<script>

        $(document)
            .ajaxStart(function () {
                $('#AjaxLoader').show();
            })
            .ajaxStop(function () {
                $('#AjaxLoader').hide();
            });
        function showloader() {
            $('#AjaxLoader').show();
        }
        function hideloader() {
            $('#AjaxLoader').hide();
        }
</script>
    <script src="~/Content/js/vendor/jquery-1.12.4.min.js"></script>
    <script>
        $(function () {
          //  debugger;
            $("[id*=submit]").bind("click", function () {
                debugger;
                if ($("[id*=ApplicationID]").val() == "")
                {
                    showAlert("Please Enter Application No !!");
                    return false;
                }
                if ($("[id*=DOB]").val() == "")
                {
                    showAlert("Please Enter DOB !!");
                    return false;
                }
                if ($("[id*=DOB]").val().length != 10)
                {
                    showAlert("Please Enter Correct  DOB !!");
                    return false;
                }
                var user =
                {
                    ApplicationNo: $("[id*=ApplicationID]").val(),
                    DOB: $("[id*=DOB]").val(),
                };
                showloader();
                $.ajax({
                    type: "POST",
                    url: "/Home/ResetPass",
                    data: user,
                    success: function (data) {
                        hideloader();
                        //console.log("value jo aa rahi hai" + JSON.stringify(data));
                        debugger;
                        if (data.data.Status) {
                            showAlert(data.data.Msg);
                            window.location.href = "/Student/Login";
                        }
                        else {
                            showAlert(data.data.Msg);
                        }
                    },
                    Error: function (data) {
                        hideloader();
                        showAlert("coming in error");
                    }
                });
                return false;
            });
        });
    </script>

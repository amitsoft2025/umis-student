
@{
    Layout = null;
}

<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>coinbase</title>
</head>
<body>
    <div>
        @using (Html.BeginForm("coinbase", "Home", FormMethod.Post, new { id = "myform", enctype = "multipart/form-data" }))
        {
            <br />
            @Html.TextBox("name", "", new { @class = "form-control", @required = "required", @placeholder = "name" })
            @Html.TextBox("vardescription", "", new { @class = "form-control", @required = "required", @placeholder = "vardescription" })
            @Html.TextBox("price", "", new { @class = "form-control", @required = "required", @placeholder = "price" })
            <br /> <br />
            <input type="submit" value="submit" />

        }
    </div>
</body>
</html>
